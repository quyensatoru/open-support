{
    "name": "mida-agent",
    "version": "0.1.0",
    "private": true,
    "description": "MIDA internal AI agent workspace",
    "type": "module",
    "packageManager": "pnpm@10.8.1",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "turbo dev --parallel",
        "dev:server": "pnpm --filter @mida-agent/server dev",
        "dev:admin": "pnpm --filter @mida-agent/admin dev",
        "build": "turbo build",
        "typecheck": "turbo typecheck",
        "lint": "turbo lint",
        "test": "vitest run",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@langchain/core": "^1.0.0",
        "@langchain/langgraph": "^1.1.5",
        "@langchain/openai": "^1.0.0",
        "@modelcontextprotocol/sdk": "^1.28.0",
        "dotenv": "^17.3.1",
        "fastify": "^5.6.0",
        "langchain": "^1.0.0",
        "playwright": "^1.60.0",
        "pino": "^10.1.0",
        "zod": "^4.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^24.12.0",
        "eslint": "^9.39.4",
        "globals": "^16.5.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "turbo": "^2.6.3",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.3.1",
        "vitest": "^4.1.0"
    }
}
